{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "agent-pulse hook --provider claude --event notification",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "agent-pulse hook --provider claude --event session_end",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "agent-pulse hook --provider claude --event session_start",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "agent-pulse hook --provider claude --event stop",
            "type": "command"
          }
        ]
      }
    ]
  }
}
